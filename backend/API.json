{
  "info": {
    "name": "Tweeter API",
    "_postman_id": "9c1f0c2a-1111-2222-3333-abcdef123456",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "" },
    { "key": "refresh", "value": "" },
    { "key": "user_uuid", "value": "USER_UUID" },
    { "key": "tweet_id", "value": "1" }
  ],
  "item": [
    {
      "name": "1. Register a new user",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/accounts/register/",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"password2\": \"SecurePass123!\",\n  \"first_name\": \"Test\",\n  \"last_name\": \"User\",\n  \"bio\": \"Hello world\"\n}"
        }
      }
    },
    {
      "name": "2. Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/accounts/login/",
        "body": {
          "mode": "raw",
          "raw": "{\"username\":\"testuser\",\"password\":\"SecurePass123!\"}"
        }
      }
    },
    {
      "name": "3. Refresh access token",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{base_url}}/api/accounts/refresh/",
        "body": {
          "mode": "raw",
          "raw": "{\"refresh\":\"{{refresh}}\"}"
        }
      }
    },
    {
      "name": "4. Get own profile",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/profile/"
      }
    },
    {
      "name": "5. Update profile (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"new_username\",\n  \"email\": \"new@example.com\",\n  \"bio\": \"Updated bio\"\n}"
        },
        "url": "{{base_url}}/api/accounts/profile/"
      }
    },
    {
      "name": "6. Change password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"old_password\": \"SecurePass123!\",\n  \"new_password\": \"NewSecurePass456!\",\n  \"confirm_new_password\": \"NewSecurePass456!\"\n}"
        },
        "url": "{{base_url}}/api/accounts/profile/change-password/"
      }
    },
    {
      "name": "7. Upload profile picture",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "profile_picture", "type": "file", "src": "" }
          ]
        },
        "url": "{{base_url}}/api/accounts/profile/"
      }
    },
    {
      "name": "8. Upload profile banner",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "profile_banner", "type": "file", "src": "" }
          ]
        },
        "url": "{{base_url}}/api/accounts/profile/"
      }
    },
    {
      "name": "9. Delete own account",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/profile/"
      }
    },
    {
      "name": "10. Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"refresh\":\"{{refresh}}\"}"
        },
        "url": "{{base_url}}/api/accounts/logout/"
      }
    },
    {
      "name": "11. List users",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/users/"
      }
    },
    {
      "name": "12. Get user by UUID",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/users/{{user_uuid}}/"
      }
    },
    {
      "name": "13. Follow user",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"followee_id\":\"{{user_uuid}}\"}"
        },
        "url": "{{base_url}}/api/accounts/follow/"
      }
    },
    {
      "name": "14. Unfollow user",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"followee_id\":\"{{user_uuid}}\"}"
        },
        "url": "{{base_url}}/api/accounts/unfollow/"
      }
    },
    {
      "name": "15. Public timeline",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/timeline/public/?page=1&page_size=10"
      }
    },
    {
      "name": "16. Private timeline",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/timeline/private/?page=1&page_size=10"
      }
    },
    {
      "name": "17. User tweets",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/users/{{user_uuid}}/tweets/"
      }
    },
    {
      "name": "18. Followers",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/users/{{user_uuid}}/followers/"
      }
    },
    {
      "name": "19. Following",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/accounts/users/{{user_uuid}}/following/"
      }
    },
    {
      "name": "20. List tweets",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/tweets/?page=1&page_size=10"
      }
    },
    {
      "name": "21. Get tweet",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/tweets/{{tweet_id}}/"
      }
    },
    {
      "name": "22. Create tweet (text only)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"content\":\"Hello, Tweeter!\"}"
        },
        "url": "{{base_url}}/api/tweets/"
      }
    },
    {
      "name": "23. Create tweet with media",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "content", "value": "Check out this photo!", "type": "text" },
            { "key": "media", "type": "file", "src": "" }
          ]
        },
        "url": "{{base_url}}/api/tweets/"
      }
    },
    {
      "name": "24. Create reply tweet",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"content\":\"Great point!\",\"parent_tweet\":{{tweet_id}}}"
        },
        "url": "{{base_url}}/api/tweets/"
      }
    },
    {
      "name": "25. Delete tweet",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/tweets/{{tweet_id}}/"
      }
    },
    {
      "name": "26. Like tweet",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/tweets/{{tweet_id}}/like/"
      }
    },
    {
      "name": "27. Unlike tweet",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/tweets/{{tweet_id}}/unlike/"
      }
    },
    {
      "name": "28. Retweet",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/tweets/{{tweet_id}}/retweet/"
      }
    },
    {
      "name": "29. Unretweet",
      "request": {
        "method": "POST",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base_url}}/api/tweets/{{tweet_id}}/unretweet/"
      }
    }
  ]
}